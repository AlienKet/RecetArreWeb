@page "/rankings"
@using Microsoft.AspNetCore.Authorization
@using RecetArreWeb.DTOs
@attribute [Authorize]
@inject IRecetaService recetaService
@inject NavigationManager navigation

<PageTitle>Ranking de Recetas</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🏆 Top Recetas</h1>
        <p class="text-muted mb-0">Las recetas mejor valoradas por la comunidad</p>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (recetasRanking == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-warning" role="status"></div>
                    <p class="mt-2 text-muted">Calculando posiciones...</p>
                </div>
            }
            else if (!recetasRanking.Any())
            {
                <div class="text-center py-5">
                    <p class="text-muted">Aún no hay recetas registradas para mostrar un ranking.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center" style="width: 100px;">Posición</th>
                                <th>Título de la Receta</th>
                                <th>Calificación</th>
                                <th class="text-center" style="width: 150px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int posicion = 1;
                            }
                            @foreach (var receta in recetasRanking)
                            {
                                <tr>
                                    <td class="text-center">
                                        @if (posicion == 1)
                                        {
                                            <span class="badge bg-warning text-dark fs-5">🥇 1</span>
                                        }
                                        else if (posicion == 2)
                                        {
                                            <span class="badge bg-secondary fs-6">🥈 2</span>
                                        }
                                        else if (posicion == 3)
                                        {
                                            <span class="badge" style="background-color: #cd7f32; font-size: 1rem;">🥉 3</span>
                                        }
                                        else
                                        {
                                            <span class="fw-bold text-muted">#@posicion</span>
                                        }
                                    </td>
                                    <td class="fw-bold">@receta.Titulo</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @* Renderizado de estrellas *@
                                            <span class="text-warning fs-5 me-2">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                   
                                                    if (i <= Math.Round(receta.PromedioCalificacion))
                                                    {
                                                        <text>★</text>
                                                    }
                                                    else
                                                    {
                                                        <text>☆</text>
                                                    }
                                                }
                                            </span>
                                            <span class="text-muted small">(@receta.PromedioCalificacion.ToString("0.0"))</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-primary" @onclick="() => VerDetalles(receta.Id)">
                                            Ver Detalles
                                        </button>
                                    </td>
                                </tr>
                                posicion++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<RecetaDto>? recetasRanking;

    protected override async Task OnInitializedAsync()
    {
        // 1. Obtenemos todas las recetas
        var todasLasRecetas = await recetaService.ObtenerTodas();

        if (todasLasRecetas != null)
        {
            // 2. Las ordenamos de mayor a menor calificación y las asignamos a la lista
            recetasRanking = todasLasRecetas
                .OrderByDescending(r => r.PromedioCalificacion)
                .ToList();
        }
    }

    private void VerDetalles(int id)
    {
        // Navega a la vista de detalles que ya tienes hecha
        navigation.NavigateTo($"recetas/{id}");
    }
}