@page "/recetas/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@using RecetArreWeb.DTOs
@attribute [Authorize]
@inject IRecetaService recetaService
@inject ICategoriaService categoriaService
@inject IIngredienteService ingredienteService
@inject NavigationManager navigation

<PageTitle>Detalle de Receta</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Detalle de la Receta</h1>
        <div>
            <button class="btn btn-info me-2 text-white" @onclick="IrAComentarios">
                💬 Ver Comentarios
            </button>
            <button class="btn btn-secondary" @onclick="Volver">Volver</button>
        </div>
    </div>

    @if (receta == null || categorias == null || todosLosIngredientes == null)
    {
        <div class="text-center py-4">
            <div class="spinner-border" role="status"></div>
            <p class="mt-2">Cargando información de la receta...</p>
        </div>
    }
    else
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                    <h2 class="card-title text-primary mb-0">@receta.Titulo</h2>

                    @* Visualización de las Categorías como Badges *@
                    <div class="d-flex flex-wrap gap-1">
                        @if (receta.CategoriaIds != null && receta.CategoriaIds.Any())
                        {
                            @foreach (var catId in receta.CategoriaIds)
                            {
                                var nombreCat = categorias.FirstOrDefault(c => c.Id == catId)?.Nombre;
                                if (!string.IsNullOrEmpty(nombreCat))
                                {
                                    <span class="badge bg-info text-dark fs-6">@nombreCat</span>
                                }
                            }
                        }
                        else
                        {
                            <span class="badge bg-secondary fs-6">Sin Categoría</span>
                        }
                    </div>
                </div>

                <hr />

                <p class="card-text"><strong>Descripción:</strong> @receta.Descripcion</p>
                <p class="card-text"><strong>Instrucciones:</strong> @receta.Instrucciones</p>

                <div class="row mt-3 border-top pt-3">
                    <div class="col-md-4 mb-2">
                        <strong>⏱ Tiempo Total:</strong> @(receta.TiempoPreparacionMinutos + receta.TiempoCoccionMinutos) min
                    </div>
                    <div class="col-md-4 mb-2">
                        <strong>🍽 Porciones:</strong> @receta.Porciones
                    </div>
                    <div class="col-md-4 mb-2">
                        <strong>📅 Creada:</strong> @receta.CreadoUtc.ToLocalTime().ToString("dd/MM/yyyy")
                    </div>
                </div>
            </div>
        </div>

        @* Sección de Ingredientes Detallados *@
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h4 class="mb-0">Ingredientes Requeridos</h4>
            </div>
            <ul class="list-group list-group-flush">
                @if (receta.IngredienteIds != null && receta.IngredienteIds.Any())
                {
                    @foreach (var id in receta.IngredienteIds)
                    {
                        var ingrediente = todosLosIngredientes.FirstOrDefault(i => i.Id == id);
                        <li class="list-group-item d-flex align-items-center">
                            <span class="text-success me-2">✔</span>
                            @if (ingrediente != null)
                            {
                                <span>@ingrediente.Nombre <small class="text-muted">(@ingrediente.UnidadMedida)</small></span>
                            }
                            else
                            {
                                <span class="text-muted">Ingrediente no encontrado (ID: @id)</span>
                            }
                        </li>
                    }
                }
                else
                {
                    <li class="list-group-item text-muted text-center py-3">No hay ingredientes registrados para esta receta.</li>
                }
            </ul>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    private RecetaDto? receta;
    private List<CategoriaDto>? categorias;
    private List<IngredienteDto>? todosLosIngredientes;

    protected override async Task OnInitializedAsync()
    {
        var tareaReceta = recetaService.ObtenerPorId(Id);
        var tareaCategorias = categoriaService.ObtenerTodas();
        var tareaIngredientes = ingredienteService.ObtenerTodos();

        await Task.WhenAll(tareaReceta, tareaCategorias, tareaIngredientes);

        receta = tareaReceta.Result;
        categorias = tareaCategorias.Result;
        todosLosIngredientes = tareaIngredientes.Result;
    }

    private void Volver() => navigation.NavigateTo("recetas");
    private void IrAComentarios() => navigation.NavigateTo($"comentarios/{Id}");
}