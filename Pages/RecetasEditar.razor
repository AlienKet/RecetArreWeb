@page "/recetas/editar/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@using RecetArreWeb.DTOs
@attribute [Authorize]
@inject IRecetaService recetaService
@inject ICategoriaService categoriaService
@inject IIngredienteService ingredienteService
@inject NavigationManager navigation

<PageTitle>Editar Receta</PageTitle>

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Modificar Receta</h3>
        </div>
        <div class="card-body">
            @if (modeloEdicion == null || categorias == null || todosLosIngredientes == null)
            {
                <div class="text-center py-4">
                    <div class="spinner-border" role="status"></div>
                    <p class="mt-2">Cargando datos de la receta...</p>
                </div>
            }
            else
            {
                <EditForm Model="modeloEdicion" OnValidSubmit="GuardarCambios">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Título</label>
                        <InputText class="form-control" @bind-Value="modeloEdicion.Titulo" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Descripción Corta</label>
                        <InputTextArea class="form-control" @bind-Value="modeloEdicion.Descripcion" />
                    </div>

                    @* SECCIÓN: Selección de Categorías *@
                    <div class="mb-3">
                        <label class="form-label fw-bold">Categorías de la Receta</label>
                        <div class="border rounded p-3 bg-light" style="max-height: 150px; overflow-y: auto;">
                            @if (!categorias.Any())
                            {
                                <p class="text-muted small mb-0">No hay categorías registradas en el sistema.</p>
                            }
                            else
                            {
                                <div class="row">
                                    @foreach (var cat in categorias)
                                    {
                                        <div class="col-md-4 col-sm-6 mb-2">
                                            <div class="form-check">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       id="editcat-@cat.Id"
                                                       checked="@modeloEdicion.CategoriaIds.Contains(cat.Id)"
                                                       @onchange="@((ChangeEventArgs e) => AlternarCategoria(cat.Id, e.Value!))" />
                                                <label class="form-check-label small" for="editcat-@cat.Id">
                                                    @cat.Nombre
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    @* SECCIÓN: Selección de Ingredientes *@
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ingredientes de la Receta</label>
                        <div class="border rounded p-3 bg-light" style="max-height: 150px; overflow-y: auto;">
                            @if (!todosLosIngredientes.Any())
                            {
                                <p class="text-muted small mb-0">No hay ingredientes registrados en el sistema.</p>
                            }
                            else
                            {
                                <div class="row">
                                    @foreach (var ing in todosLosIngredientes)
                                    {
                                        <div class="col-md-6 mb-2">
                                            <div class="form-check">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       id="editing-@ing.Id"
                                                       checked="@modeloEdicion.IngredienteIds.Contains(ing.Id)"
                                                       @onchange="@((ChangeEventArgs e) => AlternarIngrediente(ing.Id, e.Value!))" />
                                                <label class="form-check-label small" for="editing-@ing.Id">
                                                    @ing.Nombre <span class="text-muted">(@ing.UnidadMedida)</span>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Pasos / Instrucciones</label>
                        <InputTextArea class="form-control" rows="5" @bind-Value="modeloEdicion.Instrucciones" />
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Preparación (min)</label>
                            <InputNumber class="form-control" @bind-Value="modeloEdicion.TiempoPreparacionMinutos" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Cocción (min)</label>
                            <InputNumber class="form-control" @bind-Value="modeloEdicion.TiempoCoccionMinutos" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Porciones</label>
                            <InputNumber class="form-control" @bind-Value="modeloEdicion.Porciones" />
                        </div>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <InputCheckbox class="form-check-input" id="checkPub" @bind-Value="modeloEdicion.EstaPublicado" />
                        <label class="form-check-label" for="checkPub">Publicar receta</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">Guardar Cambios</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private RecetaModificacionDto? modeloEdicion;
    private List<CategoriaDto>? categorias;
    private List<IngredienteDto>? todosLosIngredientes;

    protected override async Task OnInitializedAsync()
    {
        var tareaReceta = recetaService.ObtenerPorId(Id);
        var tareaCategorias = categoriaService.ObtenerTodas();
        var tareaIngredientes = ingredienteService.ObtenerTodos();

        await Task.WhenAll(tareaReceta, tareaCategorias, tareaIngredientes);

        var receta = tareaReceta.Result;
        categorias = tareaCategorias.Result;
        todosLosIngredientes = tareaIngredientes.Result;

        if (receta != null)
        {
            modeloEdicion = new RecetaModificacionDto
            {
                Titulo = receta.Titulo,
                Descripcion = receta.Descripcion,
                Instrucciones = receta.Instrucciones,
                TiempoPreparacionMinutos = receta.TiempoPreparacionMinutos,
                TiempoCoccionMinutos = receta.TiempoCoccionMinutos,
                Porciones = receta.Porciones,
                EstaPublicado = receta.EstaPublicado,
                CategoriaIds = receta.CategoriaIds ?? new List<int>(),
                IngredienteIds = receta.IngredienteIds ?? new List<int>()
            };
        }
    }

    private void AlternarCategoria(int id, object marcado)
    {
        if (modeloEdicion == null) return;

        if ((bool)marcado)
        {
            if (!modeloEdicion.CategoriaIds.Contains(id))
                modeloEdicion.CategoriaIds.Add(id);
        }
        else
        {
            modeloEdicion.CategoriaIds.Remove(id);
        }
    }

    private void AlternarIngrediente(int id, object marcado)
    {
        if (modeloEdicion == null) return;

        if ((bool)marcado)
        {
            if (!modeloEdicion.IngredienteIds.Contains(id))
                modeloEdicion.IngredienteIds.Add(id);
        }
        else
        {
            modeloEdicion.IngredienteIds.Remove(id);
        }
    }

    private async Task GuardarCambios()
    {
        if (modeloEdicion != null)
        {
            var exito = await recetaService.Actualizar(Id, modeloEdicion);
            if (exito) navigation.NavigateTo("recetas");
        }
    }

    private void Cancelar() => navigation.NavigateTo("recetas");
}