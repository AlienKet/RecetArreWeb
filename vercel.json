{
  "builds": [
    {
      "src": "RecetArreWeb.csproj",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "dotnet publish -c Release",
        "distDir": "bin/Release/net8.0/publish/wwwroot"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}